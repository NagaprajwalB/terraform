# versions.tf
# Pins the Terraform CLI version and required provider versions.
# Sometimes merged directly into providers.tf instead of kept separate.

terraform {
  required_version = ">= 1.5.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
    random = {
      source  = "hashicorp/random"
      version = "~> 3.6"
    }
  }
}
